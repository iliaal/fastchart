# Release metadata for this extension: name, version macro location,
# repo slug, supported PHP build matrix, configure flags. Consumed by
# the release tooling at tag time.

extension: fastchart
version_macro: PHP_FASTCHART_VERSION
version_file: php_fastchart.h
repo: iliaal/fastchart
build_matrix:
  - PHP-8.3
  - PHP-8.4
  - PHP-8.5
configure_base: "--enable-fastchart --enable-fastchart-dev"

# Prebuilt-binary release lanes are off because fastchart links
# libgd directly (PHP_ADD_LIBRARY(gd) in config.m4). Neither
# php/php-windows-builder nor php/pie-ext-binary-builder install
# libgd-dev, so they fail at link time. Source builds via PIE work
# fine on any host where libgd is reachable. Re-enable these lanes
# once a libgd-bundling story (system package per runner, or a
# vendored build) is wired up.
windows_ci: false
linux_prebuilt: false

# PIE install + functional smoke test. Runs against php:8.x-cli with
# libgd-dev and ext/gd provisioned inside the container, exercising the
# documented "Source builds via PIE work fine on any host where libgd is
# reachable" claim end-to-end.
smoke_test: scripts/pie-smoke.sh
